POSTGRES_DB=subboost
POSTGRES_USER=subboost
POSTGRES_PASSWORD=<choose-a-database-password>
DATABASE_URL=<postgres-connection-string>
ENCRYPTION_KEY=<generate-a-random-key>
JWT_SECRET=<generate-a-random-key>
CRON_SECRET=<generate-a-random-key>
APP_URL=http://localhost:3000
SUBBOOST_PORT=3000

# 局域网模式（可选，默认 false）。
# 开启后跳过登录鉴权，自动使用一个默认管理员账号，适合可信内网一键自托管。
# ⚠️ 会彻底关闭鉴权：仅在可信内网使用，切勿将本服务暴露到公网。
SUBBOOST_LAN_MODE=false
# 可选：自定义默认管理员用户名（默认 admin），仅允许字母/数字/点/下划线/连字符。
# SUBBOOST_LAN_ADMIN_USERNAME=admin
# 可选：给默认管理员设置密码（便于以后关闭局域网模式后仍能登录）；不设则禁用密码登录。
# SUBBOOST_LAN_ADMIN_PASSWORD=
